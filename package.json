{
  "name": "slate",
  "version": "0.1.15",
  "description": "Personal local-first notes app for code and life.",
  "main": "./out/main/index.js",
  "author": {
    "name": "Sefa Gülenayva",
    "email": "sefa@gulenayva.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "npm install --ignore-scripts && node node_modules/electron/install.js && electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite start",
    "package": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "node scripts/run-vitest-electron.mjs run",
    "test:watch": "node scripts/run-vitest-electron.mjs",
    "rebuild": "electron-builder install-app-deps"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.8.9",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language-data": "^6.5.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "codemirror": "^6.0.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hotkeys-hook": "^4.6.1",
    "react-resizable-panels": "^2.1.7",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "zustand": "^5.0.2"
  }
}
